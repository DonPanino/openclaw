# Maintainer: OpenClaw contributors
pkgname=openclaw-app
pkgver=2026.6.2
pkgrel=1
pkgdesc="OpenClaw Linux desktop companion"
arch=('x86_64' 'aarch64')
url="https://github.com/openclaw/openclaw"
license=('MIT')
depends=('openclaw' 'webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator3' 'libnotify' 'xdg-desktop-portal' 'pipewire')
makedepends=('rust' 'pnpm' 'nodejs' 'npm')
source=("$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "openclaw-openclaw-$pkgver"
  pnpm install
  pnpm ui:build
  pnpm build
  pnpm linux:build
}

package() {
  cd "openclaw-openclaw-$pkgver"
  install -Dm755 apps/linux/target/release/openclaw-linux-app "$pkgdir/usr/bin/openclaw-app"
  install -Dm644 apps/linux/packaging/aur/ai.openclaw.linux.desktop "$pkgdir/usr/share/applications/ai.openclaw.linux.desktop"
  install -Dm644 apps/linux/openclaw-app/src-tauri/icons/32x32.png "$pkgdir/usr/share/icons/hicolor/32x32/apps/ai.openclaw.linux.png"
  install -Dm644 apps/linux/openclaw-app/src-tauri/icons/128x128.png "$pkgdir/usr/share/icons/hicolor/128x128/apps/ai.openclaw.linux.png"
  install -Dm644 apps/linux/openclaw-app/src-tauri/icons/icon.png "$pkgdir/usr/share/icons/hicolor/512x512/apps/ai.openclaw.linux.png"
}
